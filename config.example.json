{
  "quiet_hours": {
    "morning_routine": {
      "start": "07:00",
      "end": "09:30",
      "allowed": ["wellbeing-nudge"]
    },
    "evening": {
      "start": "19:30",
      "end": "07:00",
      "allowed": ["wellbeing-nudge", "emergency"]
    }
  },
  "emergency_keywords": ["server_down", "security", "data_loss", "payment_failure"],
  "enabled": true,
  "routine": {
    "activities": {
      "outdoor": "running",
      "indoor": "yoga or stretching"
    },
    "wake_time": "07:00",
    "bedtime": "23:00",
    "location": ""
  },
  "messaging": {
    "channel": "cli",
    "_comment": "Options: cli, imessage, telegram, slack, webhook. See SETUP.md."
  },
  "error_registry": {
    "repeat_threshold": 3,
    "window_minutes": 10,
    "loop_threshold": 5,
    "log_patterns": ["ERROR", "FAIL", "Exception", "Traceback"]
  },
  "memory_health": {
    "paths": [],
    "max_size_kb": 50,
    "stale_days": 7
  }
}
